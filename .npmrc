# jest-expo@57 currently pulls in @react-native/jest-preset@0.86, which peer-
# requires react@^19.2.3 — one minor ahead of the react@19.1.0 that
# react-native@0.81.4 (this project's actual RN version) itself expects.
# It's a testing-tooling-only mismatch, not a runtime one: the app's real
# react/react-native versions are unaffected either way. Without this,
# `npm install`/`npm ci` fails with an ERESOLVE error.
legacy-peer-deps=true
