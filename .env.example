# BloomDaily environment variables
# All variables MUST be prefixed with EXPO_PUBLIC_ to be readable in the app
# (this means they are bundled into the client — never put secrets here).

# ---- Firebase (OPTIONAL) ----
# BloomDaily works fully offline in "Guest Mode" with zero setup.
# Fill these in only if you want real accounts + cross-device sync.
# Create a project at https://console.firebase.google.com, add a Web app,
# and copy the values from Project Settings > General > Your apps > SDK setup.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
